{
	"$schema": "https://raw.githubusercontent.com/oxc-project/oxc/refs/heads/main/npm/oxfmt/configuration_schema.json",
	"printWidth": 80,
	"singleQuote": true,
	"jsxSingleQuote": false,
	"semi": false,
	"useTabs": true,
	"tabWidth": 2,
	"jsdoc": true,
	"sortImports": {
		"groups": [
			["type-builtin", "type-external"],
			["builtin", "external"],
			["type-internal", "type-subpath", "internal", "subpath"],
			["type-parent", "type-sibling", "type-index"],
			["parent", "sibling", "index"],
			["side_effect", "side_effect_style", "style"]
		]
	},
	"sortTailwindcss": {
		"functions": ["cn", "cx", "clsx", "cva"],
		"stylesheet": "web/src/styles/base.css"
	},
	"sortPackageJson": true,
	"ignorePatterns": [
		"node_modules",
		"externals",
		"dist",
		"*.lock",
		"**/*.gen.ts",
		"**/worker-configuration.d.ts",
		"convex/_generated"
	]
}

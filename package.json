{
	"name": "argc",
	"version": "6.0.1",
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./terminal": {
			"types": "./dist/terminal.d.ts",
			"import": "./src/terminal.ts",
			"default": "./src/terminal.ts"
		}
	},
	"scripts": {
		"build": "tsgo -p tsconfig.build.json",
		"check": "bun run typecheck && bun test && bun run fmt:check",
		"test": "bun test",
		"typecheck": "tsgo --noEmit",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@typescript/native-preview": "^7.0.0-dev.20260621.1",
		"@valibot/to-json-schema": "^1.7.1",
		"oxfmt": "^0.55.0",
		"typescript": "npm:@typescript/typescript6@^6.0.1",
		"valibot": "^1.4.1"
	},
	"peerDependencies": {
		"@standard-schema/spec": "^1.0.0"
	}
}
